# ============================================
# GoldenBot — Variables de Entorno
# Copiar este archivo a .env y completar los valores
# NUNCA subir el archivo .env a GitHub
# ============================================

# ---- BASE DE DATOS ----
DATABASE_URL="postgresql://usuario:password@localhost:5432/goldenbot"

# ---- REDIS ----
REDIS_URL="redis://localhost:6379"

# ---- AUTENTICACIÓN ----
JWT_SECRET="cambiar-por-una-clave-secreta-larga-y-aleatoria"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="cambiar-por-otra-clave-secreta-diferente"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- SERVIDOR ----
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ---- FRONTEND ----
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ---- IA - OPENAI (conseguir en platform.openai.com) ----
OPENAI_API_KEY=""

# ---- IA - ANTHROPIC (conseguir en console.anthropic.com) ----
ANTHROPIC_API_KEY=""

# ---- WHATSAPP BUSINESS API (configurar en Fase 5) ----
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ---- INSTAGRAM (configurar en Fase 5) ----
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=""

# ---- CLOUDINARY (para imágenes y archivos) ----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---- SUPERADMIN INICIAL (solo para el primer seed) ----
SUPERADMIN_EMAIL="admin@goldenbot.com"
SUPERADMIN_PASSWORD="cambiar-en-produccion"
SUPERADMIN_NAME="Administrador"
